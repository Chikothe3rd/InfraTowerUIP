datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tower {
  id          String      @id @default(uuid())
  name        String
  siteCode    String      @unique
  latitude    Float
  longitude   Float
  region      String
  status      TowerStatus @default(ONLINE)
  powerSource PowerSource @default(GRID)
  fuelLevel   Float       @default(100.0)
  upSince     DateTime    @default(now())
  createdAt   DateTime    @default(now())

  tenants   Tenant[]
  telemetry Telemetry[]
  alerts    Alert[]
}

model Telemetry {
  id               String   @id @default(uuid())
  towerId          String
  tower            Tower    @relation(fields: [towerId], references: [id], onDelete: Cascade)
  timestamp        DateTime @default(now())
  gridPower        Float // kW drawn from grid
  solarPower       Float // kW from solar panels
  generatorPower   Float // kW from generator
  fuelLevel        Float // diesel tank %
  ambientTemp      Float // °C
  equipmentTemp    Float // °C
  humidity         Float // %
  doorStatus       Boolean // true = open
  smokeDetected    Boolean
  generatorRunning Boolean
  motionDetected   Boolean  @default(false)
  batterySoH       Float    @default(100.0)

  @@index([towerId, timestamp])
}

model Alert {
  id                   String         @id @default(uuid())
  towerId              String
  tower                Tower          @relation(fields: [towerId], references: [id], onDelete: Cascade)
  type                 AlertType
  severity             Severity
  message              String
  isAcknowledged       Boolean        @default(false)
  acknowledgedBy       String? // Username who acknowledged (for audit trail)
  acknowledgedAt       DateTime? // Timestamp of acknowledgment
  dispatchStatus       DispatchStatus @default(PENDING)
  dispatchedTechnician String?
  dispatchedAt         DateTime?
  resolvedAt           DateTime?
  resolutionNotes      String?
  createdAt            DateTime       @default(now())
}

enum DispatchStatus {
  PENDING
  DISPATCHED
  RESOLVED
}

model Tenant {
  id             String   @id @default(uuid())
  towerId        String
  tower          Tower    @relation(fields: [towerId], references: [id], onDelete: Cascade)
  clientName     String
  monthlyRevenue Float
  contractStart  DateTime
  contractEnd    DateTime
  isActive       Boolean  @default(true)
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  username  String
  role      String
  action    String // e.g. ALERT_ACKNOWLEDGED, TOWER_CONFIG_UPDATED, LOGIN
  targetId  String? // ID of resource affected
  details   String? // Context detail
  createdAt DateTime @default(now())
}

enum TowerStatus {
  ONLINE
  WARNING
  CRITICAL
  OFFLINE
}

enum PowerSource {
  GRID
  SOLAR
  GENERATOR
}

enum AlertType {
  INTRUSION
  UNAUTHORIZED_ACCESS
  FUEL_THEFT
  LOW_FUEL
  TEMP_HIGH
  EQUIPMENT_FAIL
  POWER_SWITCH
  SLA_BREACH
  SMOKE
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model ScheduledReport {
  id        String   @id @default(uuid())
  recipient String
  interval  String // DAILY, WEEKLY, MONTHLY
  category  String // UPTIME, POWER, SLA, FUEL, PREDICTIVE_AI
  towerId   String // 'all' or specific ID
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}
